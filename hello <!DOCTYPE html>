<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>TotalEnergies — Energy for a Better Life</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,900;1,700&family=Outfit:wght@300;400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

:root {
  --red: #E8001C;
  --red-glow: rgba(232,0,28,0.18);
  --navy: #050E1F;
  --navy2: #0B1A30;
  --navy3: #112240;
  --white: #FFFFFF;
  --off: #E8EEF7;
  --muted: #7B90B2;
  --gold: #F0A500;
  --green: #00C896;
  --border: rgba(255,255,255,0.07);
  --border2: rgba(255,255,255,0.12);
}

html { scroll-behavior: smooth; }

body {
  background: var(--navy);
  color: var(--white);
  font-family: 'Outfit', sans-serif;
  line-height: 1.6;
  overflow-x: hidden;
}

/* ─── SCROLLBAR ─── */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: var(--navy); }
::-webkit-scrollbar-thumb { background: var(--red); border-radius: 2px; }

/* ─── ANIMATED GRADIENT BG ─── */
.bg-orbs {
  position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden;
}
.orb {
  position: absolute; border-radius: 50%; filter: blur(120px); opacity: 0.22;
  animation: drift 18s ease-in-out infinite;
}
.orb1 { width: 600px; height: 600px; background: var(--red); top: -150px; left: -150px; animation-delay: 0s; }
.orb2 { width: 500px; height: 500px; background: #003A7A; top: 40%; right: -100px; animation-delay: -7s; }
.orb3 { width: 400px; height: 400px; background: #001A40; bottom: -100px; left: 30%; animation-delay: -12s; }
@keyframes drift {
  0%,100% { transform: translate(0,0) scale(1); }
  33% { transform: translate(30px,-40px) scale(1.05); }
  66% { transform: translate(-20px,30px) scale(0.95); }
}

/* ─── NAV ─── */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
  padding: 0 60px;
  display: flex; align-items: center; justify-content: space-between;
  height: 76px;
  background: rgba(5,14,31,0.85);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--border);
  transition: all 0.3s;
}
nav.scrolled { height: 64px; background: rgba(5,14,31,0.97); }

.nav-logo {
  display: flex; align-items: center; gap: 12px;
  text-decoration: none; color: var(--white);
  font-weight: 700; font-size: 17px; letter-spacing: -0.01em;
}
.logo-mark {
  width: 40px; height: 40px; background: var(--red);
  border-radius: 8px; display: flex; align-items: center; justify-content: center;
  font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 900;
  flex-shrink: 0;
}

.nav-links { display: flex; align-items: center; gap: 36px; }
.nav-links a {
  color: var(--muted); text-decoration: none; font-size: 14px; font-weight: 500;
  letter-spacing: 0.01em; transition: color 0.2s; position: relative;
}
.nav-links a:hover { color: var(--white); }
.nav-links a::after {
  content: ''; position: absolute; bottom: -4px; left: 0; right: 0; height: 1px;
  background: var(--red); transform: scaleX(0); transition: transform 0.25s;
}
.nav-links a:hover::after { transform: scaleX(1); }

.nav-cta {
  display: flex; align-items: center; gap: 12px;
}
.btn-ghost {
  padding: 8px 20px; border: 1px solid var(--border2); border-radius: 6px;
  color: var(--white); background: transparent; font-size: 14px; font-weight: 500;
  cursor: pointer; transition: all 0.2s; text-decoration: none;
}
.btn-ghost:hover { background: rgba(255,255,255,0.06); }
.btn-primary {
  padding: 10px 22px; background: var(--red); border: none; border-radius: 6px;
  color: var(--white); font-size: 14px; font-weight: 600; cursor: pointer;
  transition: all 0.2s; text-decoration: none; display: inline-flex; align-items: center; gap: 7px;
}
.btn-primary:hover { background: #C8001A; transform: translateY(-1px); box-shadow: 0 8px 28px var(--red-glow); }

/* ─── HERO ─── */
.hero {
  position: relative; z-index: 1;
  min-height: 100vh; display: flex; align-items: center;
  padding: 120px 60px 80px;
  overflow: hidden;
}

.hero-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
  background-size: 64px 64px;
  mask-image: radial-gradient(ellipse 80% 70% at 50% 50%, black 40%, transparent 100%);
}

.hero-content { max-width: 1200px; margin: 0 auto; width: 100%; }

.hero-eyebrow {
  display: inline-flex; align-items: center; gap: 10px;
  font-family: 'IBM Plex Mono', monospace; font-size: 11px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
  margin-bottom: 28px;
  opacity: 0; animation: fadeUp 0.8s 0.2s forwards;
}
.eyebrow-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); }

.hero h1 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(50px, 7vw, 96px);
  font-weight: 900; line-height: 1.0;
  letter-spacing: -0.03em;
  margin-bottom: 28px; max-width: 760px;
  opacity: 0; animation: fadeUp 0.9s 0.35s forwards;
}
.hero h1 .accent { color: var(--red); display: block; }
.hero h1 .italic { font-style: italic; }

.hero-sub {
  font-size: 18px; color: var(--muted); max-width: 520px;
  line-height: 1.75; margin-bottom: 44px;
  opacity: 0; animation: fadeUp 0.9s 0.5s forwards;
}

.hero-actions {
  display: flex; gap: 16px; flex-wrap: wrap; align-items: center;
  margin-bottom: 72px;
  opacity: 0; animation: fadeUp 0.9s 0.65s forwards;
}
.btn-hero {
  padding: 16px 34px; background: var(--red); border: none; border-radius: 8px;
  color: var(--white); font-size: 16px; font-weight: 600; cursor: pointer;
  transition: all 0.25s; display: inline-flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.btn-hero:hover { background: #C8001A; transform: translateY(-2px); box-shadow: 0 12px 36px var(--red-glow); }
.btn-hero-outline {
  padding: 15px 32px; background: transparent; border: 1px solid var(--border2); border-radius: 8px;
  color: var(--white); font-size: 16px; font-weight: 500; cursor: pointer;
  transition: all 0.2s; display: inline-flex; align-items: center; gap: 10px;
  text-decoration: none;
}
.btn-hero-outline:hover { background: rgba(255,255,255,0.05); }

.hero-stats {
  display: flex; gap: 56px; flex-wrap: wrap;
  opacity: 0; animation: fadeUp 0.9s 0.8s forwards;
}
.hero-stat { }
.hs-num {
  font-family: 'Playfair Display', serif;
  font-size: 42px; font-weight: 700; line-height: 1;
  color: var(--white); margin-bottom: 4px;
}
.hs-num sup { font-size: 22px; color: var(--red); }
.hs-label { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 0.1em; text-transform: uppercase; }

/* ─── TICKER ─── */
.ticker-wrap {
  position: relative; z-index: 1; overflow: hidden;
  background: var(--navy2); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);
  padding: 18px 0;
}
.ticker {
  display: flex; gap: 0; white-space: nowrap;
  animation: ticker 30s linear infinite;
}
.ticker-item {
  display: inline-flex; align-items: center; gap: 16px;
  font-family: 'IBM Plex Mono', monospace; font-size: 12px;
  color: var(--muted); letter-spacing: 0.06em; text-transform: uppercase;
  padding: 0 48px;
}
.ticker-item .sep { color: var(--red); font-size: 8px; }
.ticker-logo {
  font-family: 'Outfit', sans-serif; font-weight: 700; font-size: 14px; color: rgba(255,255,255,0.3);
  letter-spacing: -0.01em;
}
@keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ─── SECTIONS ─── */
.section { position: relative; z-index: 1; padding: 100px 60px; }
.section-inner { max-width: 1200px; margin: 0 auto; }

.section-label {
  font-family: 'IBM Plex Mono', monospace; font-size: 11px;
  letter-spacing: 0.2em; text-transform: uppercase; color: var(--red);
  display: flex; align-items: center; gap: 14px; margin-bottom: 20px;
}
.section-label::after { content: ''; flex: none; width: 40px; height: 1px; background: var(--red); }

.section-h2 {
  font-family: 'Playfair Display', serif;
  font-size: clamp(34px, 4vw, 56px); font-weight: 900;
  letter-spacing: -0.025em; line-height: 1.1;
  margin-bottom: 18px;
}
.section-h2 em { color: var(--red); font-style: italic; }
.section-h2 .line2 { color: var(--muted); }

.section-sub {
  color: var(--muted); font-size: 17px; max-width: 540px; line-height: 1.75; margin-bottom: 60px;
}

/* ─── SOLUTIONS ─── */
.solutions-bg { background: var(--navy2); }

.solutions-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  border: 2px solid var(--border);
  border-radius: 16px; overflow: hidden;
}

.sol-card {
  background: var(--navy); padding: 40px 36px;
  position: relative; overflow: hidden; cursor: pointer;
  transition: background 0.3s;
  border: none; color: var(--white); text-align: left;
}
.sol-card:hover { background: var(--navy3); }
.sol-card::before {
  content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px;
  background: var(--red); transform: scaleX(0); transition: transform 0.3s; transform-origin: left;
}
.sol-card:hover::before { transform: scaleX(1); }

.sol-icon {
  width: 52px; height: 52px; border-radius: 12px;
  background: rgba(232,0,28,0.1); display: flex; align-items: center; justify-content: center;
  font-size: 26px; margin-bottom: 22px;
  transition: background 0.3s;
}
.sol-card:hover .sol-icon { background: rgba(232,0,28,0.2); }

.sol-card h3 { font-size: 18px; font-weight: 700; margin-bottom: 10px; }
.sol-card p { font-size: 14px; color: var(--muted); line-height: 1.6; margin-bottom: 20px; }
.sol-link {
  font-family: 'IBM Plex Mono', monospace; font-size: 11px;
  letter-spacing: 0.08em; text-transform: uppercase;
  color: var(--red); display: flex; align-items: center; gap: 8px;
  transition: gap 0.2s;
}
.sol-card:hover .sol-link { gap: 14px; }

/* ─── ENERGY TRANSITION ─── */
.transition-section { background: var(--navy); }

.transition-layout {
  display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center;
}

.transition-visual {
  position: relative; height: 480px;
}
.t-circle-bg {
  position: absolute; inset: 0;
  background: radial-gradient(circle at 50% 50%, rgba(232,0,28,0.06) 0%, transparent 70%);
  border-radius: 50%;
}
.t-rings {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
}
.t-ring {
  position: absolute; border-radius: 50%; border: 1px solid var(--border);
  animation: spinRing 20s linear infinite;
}
.t-ring:nth-child(1) { width: 380px; height: 380px; animation-duration: 30s; }
.t-ring:nth-child(2) { width: 280px; height: 280px; animation-duration: 20s; animation-direction: reverse; border-color: rgba(232,0,28,0.15); }
.t-ring:nth-child(3) { width: 180px; height: 180px; animation-duration: 15s; }
@keyframes spinRing { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }

.t-ring::after {
  content: ''; position: absolute; top: -4px; left: 50%; transform: translateX(-50%);
  width: 8px; height: 8px; border-radius: 50%; background: var(--red);
  box-shadow: 0 0 12px var(--red);
}

.t-center {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
  text-align: center; z-index: 2;
}
.t-center-num {
  font-family: 'Playfair Display', serif; font-size: 54px; font-weight: 900;
  color: var(--white); line-height: 1;
}
.t-center-num span { color: var(--red); }
.t-center-label { font-family: 'IBM Plex Mono', monospace; font-size: 11px; color: var(--muted); letter-spacing: 0.12em; text-transform: uppercase; margin-top: 6px; }

.t-metrics { display: flex; flex-direction: column; gap: 20px; margin-top: 40px; }
.t-metric {
  display: flex; flex-direction: column; gap: 6px;
}
.t-metric-head { display: flex; justify-content: space-between; align-items: center; }
.t-metric-label { font-size: 14px; font-weight: 500; }
.t-metric-val { font-family: 'IBM Plex Mono', monospace; font-size: 13px; color: var(--green); }
.t-bar-track { height: 4px; background: rgba(255,255,255,0.07); border-radius: 2px; overflow: hidden; }
.t-bar-fill { height: 100%; background: linear-gradient(90deg, var(--red), var(--gold)); border-radius: 2px; }

/* ─── CASE STUDIES ─── */
.cases-bg { background: var(--navy2); }

.cases-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; }

.case-card {
  background: var(--navy); border: 1px solid var(--border);
  border-radius: 14px; overflow: hidden; cursor: pointer;
  transition: all 0.3s; position: relative;
}
.case-card:hover { border-color: rgba(232,0,28,0.3); transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.4); }

.case-img {
  height: 200px; position: relative; overflow: hidden;
  display: flex; align-items: flex-end; padding: 24px;
}
.case-card:nth-child(1) .case-img { background: linear-gradient(135deg, #0D2137 0%, #1A3A5C 50%, #0D2137 100%); }
.case-card:nth-child(2) .case-img { background: linear-gradient(135deg, #1A0A08 0%, #3D1410 50%, #1A0A08 100%); }
.case-card:nth-child(3) .case-img { background: linear-gradient(135deg, #071A0D 0%, #0E3320 50%, #071A0D 100%); }
.case-card:nth-child(4) .case-img { background: linear-gradient(135deg, #15100A 0%, #2E2010 50%, #15100A 100%); }

.case-tag {
  font-family: 'IBM Plex Mono', monospace; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase;
  padding: 5px 12px; border-radius: 4px; background: rgba(255,255,255,0.1); color: var(--white);
}
.case-emoji { position: absolute; top: 24px; right: 24px; font-size: 40px; opacity: 0.5; }

.case-body { padding: 28px; }
.case-body h3 { font-size: 18px; font-weight: 700; line-height: 1.35; margin-bottom: 10px; }
.case-body p { font-size: 14px; color: var(--muted); line-height: 1.65; margin-bottom: 20px; }

.case-result {
  display: flex; gap: 24px; padding-top: 18px; border-top: 1px solid var(--border);
}
.cr-item { }
.cr-val { font-family: 'Playfair Display', serif; font-size: 26px; font-weight: 700; color: var(--green); }
.cr-label { font-size: 12px; color: var(--muted); margin-top: 2px; }

/* ─── TESTIMONIALS ─── */
.testimonials-section { background: var(--navy); }

.testimonials-layout {
  display: grid; grid-template-columns: 1fr 1fr; gap: 32px; align-items: start;
}

.testi-main {
  background: var(--navy2); border: 1px solid var(--border);
  border-radius: 16px; padding: 44px; position: relative;
}
.quote-mark {
  font-family: 'Playfair Display', serif; font-size: 100px; line-height: 0.6;
  color: var(--red); opacity: 0.3; position: absolute; top: 32px; left: 36px;
}
.testi-text {
  font-size: 20px; line-height: 1.7; font-weight: 400; color: var(--off);
  position: relative; z-index: 1; margin-bottom: 32px; margin-top: 20px;
}
.testi-author { display: flex; align-items: center; gap: 16px; }
.testi-avatar {
  width: 48px; height: 48px; border-radius: 50%;
  background: linear-gradient(135deg, var(--red), #660010);
  display: flex; align-items: center; justify-content: center;
  font-weight: 700; font-size: 18px; flex-shrink: 0;
}
.testi-name { font-weight: 600; font-size: 15px; }
.testi-role { font-size: 13px; color: var(--muted); }

.testi-sidebar { display: flex; flex-direction: column; gap: 16px; }
.testi-mini {
  background: var(--navy2); border: 1px solid var(--border);
  border-radius: 12px; padding: 24px; cursor: pointer; transition: all 0.2s;
}
.testi-mini:hover { border-color: rgba(232,0,28,0.25); }
.testi-mini p { font-size: 14px; color: var(--muted); line-height: 1.6; margin-bottom: 14px; }
.testi-mini-author { display: flex; align-items: center; gap: 12px; }
.tma {
  width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
  display: flex; align-items: center; justify-content: center; font-size: 14px; font-weight: 700;
}
.tma-b { background: linear-gradient(135deg, #004080, #001A40); }
.tma-g { background: linear-gradient(135deg, #006040, #002A1A); }
.tma-o { background: linear-gradient(135deg, #804000, #402000); }
.tma-name { font-weight: 600; font-size: 13px; }
.tma-role { font-size: 12px; color: var(--muted); }

/* ─── LEAD FORM ─── */
.form-section { background: var(--navy2); }

.form-layout { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: center; }

.form-trust { }
.trust-points { margin-top: 40px; display: flex; flex-direction: column; gap: 20px; }
.tp { display: flex; align-items: flex-start; gap: 16px; }
.tp-icon {
  width: 42px; height: 42px; border-radius: 10px;
  background: rgba(232,0,28,0.08); border: 1px solid rgba(232,0,28,0.15);
  display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0;
}
.tp-text h4 { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
.tp-text p { font-size: 13px; color: var(--muted); line-height: 1.5; }

.form-box {
  background: var(--navy); border: 1px solid var(--border2);
  border-radius: 16px; padding: 44px;
}
.form-box h3 { font-size: 22px; font-weight: 700; margin-bottom: 6px; }
.form-box .form-sub { font-size: 14px; color: var(--muted); margin-bottom: 32px; }

.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { margin-bottom: 18px; display: flex; flex-direction: column; gap: 8px; }
.form-group label { font-size: 13px; font-weight: 500; color: var(--off); letter-spacing: 0.01em; }
.form-group input, .form-group select, .form-group textarea {
  background: rgba(255,255,255,0.04); border: 1px solid var(--border2);
  border-radius: 8px; padding: 12px 16px;
  color: var(--white); font-family: 'Outfit', sans-serif; font-size: 14px;
  transition: all 0.2s; width: 100%; outline: none;
  appearance: none;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  border-color: rgba(232,0,28,0.5); background: rgba(232,0,28,0.04);
}
.form-group input::placeholder, .form-group textarea::placeholder { color: rgba(255,255,255,0.22); }
.form-group select option { background: var(--navy3); color: var(--white); }
.form-group textarea { resize: vertical; min-height: 100px; }
.form-submit {
  width: 100%; padding: 16px; background: var(--red); border: none; border-radius: 8px;
  color: var(--white); font-family: 'Outfit', sans-serif; font-size: 16px; font-weight: 600;
  cursor: pointer; transition: all 0.25s; display: flex; align-items: center; justify-content: center; gap: 10px;
  margin-top: 8px;
}
.form-submit:hover { background: #C8001A; box-shadow: 0 8px 28px var(--red-glow); }
.form-disclaimer { font-size: 12px; color: var(--muted); text-align: center; margin-top: 16px; line-height: 1.5; }

/* ─── NEWS ─── */
.news-section { background: var(--navy); }
.news-grid { display: grid; grid-template-columns: 1.5fr 1fr 1fr; gap: 24px; }

.news-card {
  background: var(--navy2); border: 1px solid var(--border);
  border-radius: 12px; overflow: hidden; cursor: pointer; transition: all 0.2s;
}
.news-card:hover { border-color: rgba(255,255,255,0.15); transform: translateY(-2px); }

.news-img { height: 200px; position: relative; overflow: hidden; }
.news-card:nth-child(1) .news-img { height: 240px; background: linear-gradient(135deg, #0D1A30 0%, #192C4A 100%); }
.news-card:nth-child(2) .news-img { background: linear-gradient(135deg, #1A0A0A 0%, #2A1010 100%); }
.news-card:nth-child(3) .news-img { background: linear-gradient(135deg, #081A10 0%, #0D2A1A 100%); }
.news-img-emoji { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 60px; opacity: 0.2; }

.news-body { padding: 22px; }
.news-cat {
  font-family: 'IBM Plex Mono', monospace; font-size: 10px; letter-spacing: 0.12em;
  text-transform: uppercase; color: var(--red); margin-bottom: 10px;
}
.news-card h3 { font-size: 16px; font-weight: 600; line-height: 1.4; margin-bottom: 10px; }
.news-card:nth-child(1) h3 { font-size: 20px; font-weight: 700; }
.news-date { font-size: 12px; color: var(--muted); margin-top: 14px; }

/* ─── FOOTER ─── */
footer {
  position: relative; z-index: 1;
  background: var(--navy2); border-top: 1px solid var(--border);
  padding: 72px 60px 36px;
}
.footer-inner { max-width: 1200px; margin: 0 auto; }
.footer-top {
  display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 60px; margin-bottom: 60px;
}
.footer-brand { }
.footer-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
.footer-logo span { font-weight: 700; font-size: 16px; }
