<script>
// Nav scroll effect
const nav = document.getElementById('nav');
window.addEventListener('scroll', () => {
  nav.classList.toggle('scrolled', window.scrollY > 60);
});

// Scroll reveal
const revealEls = document.querySelectorAll('.reveal');
const observer = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('in-view'), 80);
      observer.unobserve(e.target);
    }
  });
}, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
revealEls.forEach(el => observer.observe(el));

// Stagger child reveals within a parent
document.querySelectorAll('.solutions-grid.reveal, .cases-grid.reveal, .testimonials-layout.reveal, .news-grid.reveal').forEach(grid => {
  grid.querySelectorAll(':scope > *').forEach((child, i) => {
    child.style.transitionDelay = `${i * 80}ms`;
  });
});

// Form submit
function handleSubmit(btn) {
  btn.textContent = '✓ Request Received — We\'ll contact you within 24h';
  btn.style.background = '#00C896';
  btn.style.cursor = 'default';
  btn.disabled = true;
}

// Progress bar animation on scroll
const bars = document.querySelectorAll('.t-bar-fill');
const barObserver = new IntersectionObserver((entries) => {
  entries.forEach(e => {
    if (e.isIntersecting) {
      const width = e.target.style.width;
      e.target.style.width = '0%';
      e.target.style.transition = 'width 1.2s cubic-bezier(0.4,0,0.2,1)';
      requestAnimationFrame(() => { e.target.style.width = width; });
      barObserver.unobserve(e.target);
    }
  });
}, { threshold: 0.3 });
bars.forEach(b => barObserver.observe(b));
</script>
